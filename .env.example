APP_ENV=local

# Default mode when the request does not pass ?mode=keyword|semantic|hybrid.
SEARCH_BACKEND=keyword

LEXICAL_ENGINE=bm25
LEXICAL_INDEX_PATH=data/indexes/lexical_bm25.pkl
LEXICAL_DATA_PATH=data/chunks/corpus_chunks_v2_e5.json
LEXICAL_BUILD_LIMIT=1000

# Tao cac file nay bang notebooks/03_embedding.ipynb truoc khi bat semantic.
# Hoac build bang:
# conda run -n searchengine python scripts/build_semantic_index.py --limit 1000
SEMANTIC_INDEX_PATH=data/embeddings/e5_base/semantic_e5_base.faiss
SEMANTIC_METADATA_PATH=data/embeddings/e5_base/chunks_metadata.parquet
SEMANTIC_CONFIG_PATH=data/embeddings/e5_base/embedding_config.json
SEMANTIC_CANDIDATE_MULTIPLIER=5
SEMANTIC_MIN_CANDIDATES=50

HYBRID_RRF_K=60
HYBRID_CANDIDATE_MULTIPLIER=5
HYBRID_REQUIRE_SEMANTIC=true
